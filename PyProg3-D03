# PROG 4.2: EMI Utility Functions

# Function to calculate the Interest for the given Principle, Rate of Interest and Time
def calculate_interest(principle, roi, frequency=12):
    return round(principle * roi / (frequency * 100), 2)


# Function to calculate the EMI for the given Principle, Rate of Interest and Time
def calculate_emi(principle, roi, time):

    # Step 1: Calculate the Rate of Interest per month
    interest_per_month = calculate_interest(1, roi)

    # Step 2: Calculate the number of months
    months = time * 12

    # Step 3: Calculate the EMI using the formula
    emi = (principle * interest_per_month * (1 + interest_per_month) ** months /
           ((1 + interest_per_month) ** months - 1))

    # Step 4: Return the EMI
    return emi


# Test the function
print(f"EMI for Principle: 1000, ROI: 10, Years: 1 is {calculate_emi(1000, 10, 1)}")
