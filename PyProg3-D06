def transpose_matrix(matrix):
    for i in range(3):
        for j in range(i + 1, 3):
            matrix[i][j], matrix[j][i] = matrix[j][i], matrix[i][j]
    return matrix


matrix = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
]

print("Original Matrix:")
for row in matrix:
    print(row)

result = transpose_matrix(matrix)

print("Transpose Matrix:")
for row in result:
    print(row)